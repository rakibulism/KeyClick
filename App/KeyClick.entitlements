<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- The App Sandbox is incompatible with the system-wide CGEventTap this
         app relies on, so it must be disabled. Distribute via Developer ID +
         notarization (direct .dmg), not the Mac App Store. -->
    <key>com.apple.security.app-sandbox</key>
    <false/>
</dict>
</plist>
