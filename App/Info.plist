<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleName</key>
    <string>KeyClick</string>
    <key>CFBundleDisplayName</key>
    <string>KeyClick</string>
    <key>CFBundleIdentifier</key>
    <string>com.keyclick.app</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>LSMinimumSystemVersion</key>
    <string>13.0</string>

    <!-- Menu-bar agent: no Dock icon, no main window. -->
    <key>LSUIElement</key>
    <true/>

    <!-- Shown if any AppKit API ever surfaces a usage prompt. The Accessibility
         permission itself is requested via AXIsProcessTrustedWithOptions. -->
    <key>NSAccessibilityUsageDescription</key>
    <string>KeyClick listens to your key presses to play mechanical keyboard sounds. Nothing is recorded, stored, or sent anywhere.</string>
</dict>
</plist>
